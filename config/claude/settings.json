  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "rm -f \"$HOME/.claude/.compact-counter\" \"$HOME/.claude/.session-titled\"; \"$HOME/gh/github.com/ryosukesuto/dotfiles/bin/cmux-rename-workspace\""
          },
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-session-title-init"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-guard-main-edit"
          },
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-guard-worktree-edit"
          },
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-guard-obsidian-frontmatter"
          },
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-guard-write-path"
          },
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-suggest-compact"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-guard-command-policy"
          },
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-guard-main-push"
          },
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-guard-pr-writing"
          },
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-guard-heredoc-escape"
          },
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-guard-cyberagent-email"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-pre-compact"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f package.json ] && grep -q '\"lint\"' package.json 2>/dev/null; then pnpm run lint --silent 2>&1 | tail -20; fi",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-suggest-proofread"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-commit-log"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-shellcheck-after-edit"
          },
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-go-after-edit",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-terraform-after-edit"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cmux notify --title 'Claude Code' --subtitle 'APIエラー' --body 'レート制限または認証エラーで停止しました' || true"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "rm -f \"$HOME/.claude/.compact-counter\"; STATE=\"$HOME/.claude/compact-state.md\"; if [ -f \"$STATE\" ]; then echo '[Hook] コンテキスト圧縮完了。以下は圧縮前の作業状態です:' >&2; cat \"$STATE\" >&2; else echo '[Hook] コンテキスト圧縮完了。カウンターをリセットしました。' >&2; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-session-end"
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/gh/github.com/ryosukesuto/dotfiles/bin/cmux-rename-workspace\""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cmux notify --title 'Claude Code' --subtitle '権限確認' --body \"許可を求めています: $CLAUDE_TOOL_NAME\" || true"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cmux notify --title 'Claude Code' --subtitle 'タスク作成' --body \"$CLAUDE_TASK_DESCRIPTION\" || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cmux notify --title 'Claude Code' --subtitle '通知' --body \"$CLAUDE_NOTIFICATION\" || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
