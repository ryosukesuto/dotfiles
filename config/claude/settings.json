      "Bash(mv ~/.zshrc:*)",
      "Bash(mv ~/.zprofile:*)",
      "Bash(mv ~/.ssh/:*)",
      "Bash(mv ~/.aws/:*)",
      "Bash(mv ~/.claude/:*)",
      "Bash(sudo ifconfig:*)",
      "Bash(sudo iptables -F)",
      "Bash(brew uninstall --force:*)",
      "Bash(sudo apt-get purge:*)",
      "Bash(sudo yum remove:*)",
      "Read(~/.aws/credentials)",
      "Read(~/.ssh/id_rsa)",
      "Read(~/.ssh/id_ed25519)",
      "Read(~/.env)",
      "Read(~/.env.local)",
      "Read(~/.zsh_history)",
      "Read(~/.bash_history)",
      "Write(~/.zshrc)",
      "Write(~/.bashrc)",
      "Write(~/.gitconfig)",
      "Write(~/.ssh/config)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git push)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "~/gh/github.com/ryosukesuto/obsidian-notes"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "rm -f \"$HOME/.claude/.compact-counter\"; [ -S \"${CMUX_SOCKET_PATH:-/tmp/cmux.sock}\" ] && [ -n \"$CMUX_WORKSPACE_ID\" ] && echo \"{\\\"method\\\":\\\"workspace.rename\\\",\\\"params\\\":{\\\"title\\\":\\\"$(basename \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\")\\\",\\\"workspace_id\\\":\\\"$CMUX_WORKSPACE_ID\\\"}}\" | nc -U \"$CMUX_SOCKET_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-suggest-compact"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-pre-compact"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=\"$CLAUDE_TOOL_INPUT_file_path\"; if [ -f package.json ] && grep -q '\"lint\"' package.json 2>/dev/null; then npm run lint --silent 2>&1 | tail -20; elif command -v golangci-lint >/dev/null 2>&1 && [ -f go.mod ]; then golangci-lint run \"$FILE\" 2>&1 | tail -20; fi",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-commit-log"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cmux notify --title 'Claude Code' --subtitle 'APIエラー' --body 'レート制限または認証エラーで停止しました' || true"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "rm -f \"$HOME/.claude/.compact-counter\"; echo '[Hook] コンテキスト圧縮完了。カウンターをリセットしました。' >&2"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cmux notify --title 'Claude Code' --subtitle 'ツール失敗' --body 'ツール実行に失敗しました' || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cmux notify --title 'Claude Code' --subtitle '処理終了' --body 'タスクが完了しました' || true; HAS_COMMITS=$(git log --oneline --since='1 hour ago' --author=\"$(git config user.name)\" 2>/dev/null | head -1); if [ -n \"$HAS_COMMITS\" ]; then echo 'Tip: /times-post でtimesに投稿、/til で学びを記録できます'; fi"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cmux notify --title 'Claude Code' --subtitle '確認待ち' --body '許可を求めています' || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 \"$HOME/.claude/statusline.py\""
  },
  "outputStyle": "Concise",
  "language": "japanese",
  "sandbox": {
    "excludedCommands": [
      "cmux"
    ]
  },
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "showTurnDuration": true,
  "showClearContextOnPlanAccept": true,
  "effortLevel": "high",
  "channelsEnabled": true
}
