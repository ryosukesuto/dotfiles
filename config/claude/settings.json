  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "command -v cmux &>/dev/null && cmux rename-tab \"$(basename \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\")\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo '⚠️ 新規作成前に確認: 既存ファイルの編集ではダメですか？'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f package.json ] && grep -q '\"lint\"' package.json 2>/dev/null; then npm run lint --silent 2>/dev/null || true; fi",
            "timeout": 120,
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-commit-log"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cmux notify --title 'Claude Code' --subtitle 'ツール失敗' --body 'ツール実行に失敗しました' || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cmux notify --title 'Claude Code' --subtitle '処理終了' --body 'タスクが完了しました' || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cmux notify --title 'Claude Code' --subtitle '確認待ち' --body '許可を求めています' || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx --bun @owloops/claude-powerline@latest --theme=tokyo-night --style=powerline"
  },
  "sandbox": {
    "excludedCommands": ["cmux"]
  },
  "outputStyle": "Concise",
  "language": "japanese",
  "skipDangerousModePermissionPrompt": true,
  "showTurnDuration": true
}
