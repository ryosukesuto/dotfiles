{
  "cleanupPeriodDays": 7,
  "env": {
    "MAX_THINKING_TOKENS": "31999",
    "DISABLE_TELEMETRY": "true",
    "DISABLE_ERROR_REPORTING": "true",
    "DISABLE_BUG_COMMAND": "true",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "85",
    "CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS": "1",
    "ENABLE_TOOL_SEARCH": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
