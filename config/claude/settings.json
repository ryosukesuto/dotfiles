  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "rm -f \"$HOME/.claude/.compact-counter\" \"$HOME/.claude/.session-titled\"; [ -S \"${CMUX_SOCKET_PATH:-/tmp/cmux.sock}\" ] && [ -n \"$CMUX_WORKSPACE_ID\" ] && echo \"{\\\"method\\\":\\\"workspace.rename\\\",\\\"params\\\":{\\\"title\\\":\\\"$(d=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) && basename \"$(dirname \"$d\")\" || basename \"$(pwd)\")\\\",\\\"workspace_id\\\":\\\"$CMUX_WORKSPACE_ID\\\"}}\" | nc -U \"$CMUX_SOCKET_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-session-title"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-guard-main-edit"
          },
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-guard-worktree-edit"
          },
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-suggest-compact"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-guard-main-push"
          },
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-guard-pr-writing"
          },
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-guard-heredoc-escape"
          },
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-guard-cyberagent-email"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-pre-compact"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=\"$CLAUDE_TOOL_INPUT_file_path\"; if [ -f package.json ] && grep -q '\"lint\"' package.json 2>/dev/null; then pnpm run lint --silent 2>&1 | tail -20; elif [ -f go.mod ] && [ ! -x ./custom-gcl ]; then command -v golangci-lint >/dev/null 2>&1 && golangci-lint run \"$FILE\" 2>&1 | tail -20; fi",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-suggest-proofread"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-commit-log"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cmux notify --title 'Claude Code' --subtitle 'APIエラー' --body 'レート制限または認証エラーで停止しました' || true"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "rm -f \"$HOME/.claude/.compact-counter\"; STATE=\"$HOME/.claude/compact-state.md\"; if [ -f \"$STATE\" ]; then echo '[Hook] コンテキスト圧縮完了。以下は圧縮前の作業状態です:' >&2; cat \"$STATE\" >&2; else echo '[Hook] コンテキスト圧縮完了。カウンターをリセットしました。' >&2; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/gh/github.com/ryosukesuto/dotfiles/bin/claude-session-end"
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -S \"${CMUX_SOCKET_PATH:-/tmp/cmux.sock}\" ] && [ -n \"$CMUX_WORKSPACE_ID\" ] && echo \"{\\\"method\\\":\\\"workspace.rename\\\",\\\"params\\\":{\\\"title\\\":\\\"$(d=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) && basename \"$(dirname \"$d\")\" || basename \"$(pwd)\")\\\",\\\"workspace_id\\\":\\\"$CMUX_WORKSPACE_ID\\\"}}\" | nc -U \"$CMUX_SOCKET_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cmux notify --title 'Claude Code' --subtitle '権限確認' --body \"許可を求めています: $CLAUDE_TOOL_NAME\" || true"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cmux notify --title 'Claude Code' --subtitle 'タスク作成' --body \"$CLAUDE_TASK_DESCRIPTION\" || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cmux notify --title 'Claude Code' --subtitle '通知' --body \"$CLAUDE_NOTIFICATION\" || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 \"$HOME/.claude/statusline.py\"",
    "refreshInterval": 30
  },
  "enabledPlugins": {
    "slack@claude-plugins-official": false,
    "figma@claude-plugins-official": true,
    "codex@openai-codex": true,
    "vercel@claude-plugins-official": true
