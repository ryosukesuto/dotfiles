  },
  "outputStyle": "Concise",
  "language": "japanese",
  "sandbox": {
    "excludedCommands": [
      "cmux"
    ]
  },
  "showClearContextOnPlanAccept": true,
  "channelsEnabled": true,
  "showThinkingSummaries": true,
  "theme": "dark-ansi",
  "showTurnDuration": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "mcpServers": {
    "slack": {
      "type": "http",
      "url": "https://mcp.slack.com/mcp",
      "oauth": {
        "clientId": "1601185624273.8899143856786",
        "callbackPort": 3118
      }
    }
  }
