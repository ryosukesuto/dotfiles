      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf */:*)",
      "Bash(rm -rf .)",
      "Bash(rm -rf ..)",
      "Bash(rm -rf:*)",
      "Bash(rm -rf .:*)",
      "Bash(rm -rf ~/gh)",
      "Bash(rm -rf ~/Documents)",
      "Bash(rm -rf ~/Desktop)",
      "Bash(rm -rf ~/Downloads)",
      "Bash(rm -r:*)",
      "Bash(rm -f:*)",
      "Bash(sudo rm:*)",
      "Bash(sudo mv /etc/:*)",
      "Bash(sudo chmod 777 /)",
      "Bash(sudo chown:*)",
      "Bash(sudo kill:*)",
      "Bash(sudo killall:*)",
      "Bash(sudo pkill:*)",
