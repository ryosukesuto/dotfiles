{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ryosukesuto/dotfiles/schemas/review/bundle.schema.json",
  "title": "Review Bundle",
  "description": "Shared static context distributed to all reviewers. Generated once per review run to eliminate repeated repo exploration.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "triage_ref",
    "changed_file_manifest",
    "interface_changes",
    "risk_tags",
    "relevant_snippets",
    "review_slices",
    "path_reason_map"
  ],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "triage_ref": {
      "type": "string",
      "description": "Path or ID referring to the triage output that generated this bundle."
    },
    "changed_file_manifest": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["repo", "path", "status", "additions", "deletions"],
        "properties": {
          "repo": {"type": "string"},
          "path": {"type": "string"},
          "status": {"type": "string", "enum": ["added", "modified", "deleted", "renamed"]},
          "additions": {"type": "integer", "minimum": 0},
          "deletions": {"type": "integer", "minimum": 0}
        }
      }
    },
    "repo_summary": {
      "type": "object",
      "description": "repo_id -> summary object. Generated by a separate cache job, not per-PR.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "role": {"type": "string"},
          "key_directories": {"type": "array", "items": {"type": "string"}},
          "last_updated": {"type": "string"}
        }
      }
    },
    "interface_changes": {
      "type": "object",
      "additionalProperties": false,
      "description": "Must share shape with triage.schema.json fields: changed_symbols / changed_protos / changed_env_vars / changed_schemas.",
      "properties": {
        "symbols": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["repo", "path", "kind", "name"],
            "properties": {
              "repo": {"type": "string"},
              "path": {"type": "string"},
              "kind": {"type": "string", "enum": ["rpc", "function", "method", "type", "const", "interface"]},
              "name": {"type": "string"}
            }
          }
        },
        "protos": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["repo", "path"],
            "properties": {
              "repo": {"type": "string"},
              "path": {"type": "string"}
            }
          }
        },
        "env_vars": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["repo", "path", "name"],
            "properties": {
              "repo": {"type": "string"},
              "path": {"type": "string"},
              "name": {"type": "string"}
            }
          }
        },
        "schemas": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["repo", "path"],
            "properties": {
              "repo": {"type": "string"},
              "path": {"type": "string"},
              "name": {"type": "string"}
            }
          }
        }
      }
    },
    "risk_tags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "relevant_snippets": {
      "type": "array",
      "description": "Code around each changed hunk (+/- 30 lines).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["repo", "path", "lines", "content"],
        "properties": {
          "repo": {"type": "string"},
          "path": {"type": "string"},
          "lines": {
            "type": "object",
            "additionalProperties": false,
            "required": ["start", "end"],
            "properties": {
              "start": {"type": "integer", "minimum": 1},
              "end": {"type": "integer", "minimum": 1}
            }
          },
          "content": {"type": "string"}
        }
      }
    },
    "review_slices": {
      "type": "object",
      "description": "reviewer_id -> array of slices. Each reviewer reads only its own slice.",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repo", "path", "reason"],
          "properties": {
            "repo": {"type": "string"},
            "path": {"type": "string"},
            "hunk_ranges": {
              "type": "array",
              "minItems": 1,
              "description": "Present -> reviewer reads only these ranges. Omitted -> full file. Empty array not allowed.",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["start", "end"],
                "properties": {
                  "start": {"type": "integer", "minimum": 1},
                  "end": {"type": "integer", "minimum": 1}
                }
              }
            },
            "reason": {"type": "string"}
          }
        }
      }
    },
    "path_reason_map": {
      "type": "object",
      "description": "repo-qualified path -> reason why this path is in scope.",
      "additionalProperties": {"type": "string"}
    },
    "symbol_index": {
      "type": "object",
      "description": "Optional (PoC後の拡張). symbol_name -> list of definition/reference locations."
    },
    "ownership_hint": {
      "type": "object",
      "description": "Optional. Based on CODEOWNERS or git log."
    },
    "generated_or_vendor_flag": {
      "type": "object",
      "description": "Optional. repo:path -> boolean flag for skip."
    },
    "test_delta": {
      "type": "object",
      "description": "Optional. test file changes corresponding to changed sources."
    },
    "static_analysis_summary": {
      "type": "object",
      "description": "Optional. Semgrep / gosec / tfsec results as prior context."
    },
    "open_questions": {
      "type": "array",
      "description": "Optional. Notes from triage on ambiguous classifications.",
      "items": {"type": "string"}
    }
  }
}
