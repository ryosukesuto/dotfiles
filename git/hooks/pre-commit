#!/bin/bash
#
# pre-commit hook: mainブランチへの直接コミット・worktree外でのfeatureブランチコミットを防止
#
# 保護対象:
#   - main, master ブランチへの直接コミット
#   - メインチェックアウト（worktree外）でのfeatureブランチコミット
# 除外: git config --local wt.allowDirectCommit true を設定したリポジトリ
# バイパス: git commit --no-verify（緊急時のみ）

current_branch=$(git rev-parse --abbrev-ref HEAD)

# リポジトリ単位のopt-out（main直コミット・worktree強制の両方を解除）
if [[ "$(git config --bool wt.allowDirectCommit 2>/dev/null)" == "true" ]]; then
    exit 0
fi

# worktree外でのfeatureブランチコミットをブロック
git_dir=$(git rev-parse --absolute-git-dir 2>/dev/null)
git_common_dir=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)
if [[ "$git_dir" == "$git_common_dir" ]] \
    && [[ "$current_branch" != "main" ]] \
    && [[ "$current_branch" != "master" ]] \
    && [[ "$current_branch" != "HEAD" ]]; then
    echo ""
    echo -e "\033[0;31m[BLOCKED]\033[0m メインチェックアウトでfeatureブランチをコミットしようとしています (branch: ${current_branch})"
    echo ""
    echo "  worktreeで作業してください:"
    echo "    git stash"
    echo "    git switch main"
    echo "    git-wt add ${current_branch}"
    echo "    cd .worktrees/${current_branch} && git stash pop"
    echo ""
    echo "  除外設定: git config --local wt.allowDirectCommit true"
    echo "  緊急バイパス: git commit --no-verify"
    echo ""
    exit 1
fi

# ===== シークレットスキャン (全ブランチ共通) =====
# gitleaksが利用可能ならそちらを優先、未導入なら正規表現フォールバック
if command -v gitleaks >/dev/null 2>&1; then
    if ! gitleaks git --staged --no-banner --redact=75 -v --exit-code 1 >/tmp/gitleaks-precommit.log 2>&1; then
        echo ""
        echo -e "\033[0;31m[BLOCKED]\033[0m gitleaksがシークレットを検出しました"
        echo ""
        cat /tmp/gitleaks-precommit.log | tail -30
        echo ""
        echo "  誤検知の場合: git commit --no-verify"
        echo "  許可コメント: 行末に // gitleaks:allow"
        echo ""
        exit 1
    fi
else
    secret_patterns=(
        'AKIA[0-9A-Z]{16}'                     # AWS Access Key
        'sk-[a-zA-Z0-9]{20,}'                  # OpenAI/Stripe API Key
        'ghp_[a-zA-Z0-9]{36}'                  # GitHub PAT
        'gho_[a-zA-Z0-9]{36}'                  # GitHub OAuth
        'github_pat_[a-zA-Z0-9_]{82}'          # GitHub Fine-grained PAT
        'xoxb-[0-9]+-[a-zA-Z0-9]+'            # Slack Bot Token
        'xoxp-[0-9]+-[a-zA-Z0-9]+'            # Slack User Token
        'hooks\.slack\.com/services/T[A-Z0-9]+' # Slack Webhook
        'ya29\.[0-9A-Za-z_-]+'                 # Google OAuth Token
        'AIza[0-9A-Za-z_-]{35}'               # Google API Key
        'password\s*[:=]\s*["\x27][^"\x27]{8,}' # Hardcoded password
        'secret\s*[:=]\s*["\x27][^"\x27]{8,}'  # Hardcoded secret
    )
    staged_files=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)
    if [[ -n "$staged_files" ]]; then
        combined_pattern=$(IFS='|'; echo "${secret_patterns[*]}")
        matches=$(echo "$staged_files" | xargs grep -nE "$combined_pattern" 2>/dev/null || true)
        if [[ -n "$matches" ]]; then
            echo ""
            echo -e "\033[0;31m[BLOCKED]\033[0m シークレットらしき文字列が検出されました"
            echo ""
            echo "$matches" | head -10
            echo ""
            echo "  誤検知の場合: git commit --no-verify"
            echo ""
            exit 1
        fi
    fi
fi

# main/master以外はここで終了（feature in worktree）
if [[ "$current_branch" != "main" ]] && [[ "$current_branch" != "master" ]]; then
    exit 0
fi

echo ""
echo -e "\033[0;31m[BLOCKED]\033[0m ${current_branch} ブランチへの直接コミットは禁止されています"
echo ""
echo "  worktreeを作成してください:"
echo "    git-wt add feature/xxx"
echo ""
echo "  除外設定: git config --local wt.allowDirectCommit true"
echo "  緊急バイパス: git commit --no-verify"
echo ""
exit 1
