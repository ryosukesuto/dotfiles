#!/bin/bash
# claude-session-title-init: Set initial session title from cwd at SessionStart
# Hook: SessionStart (v2.1.152+)
#
# Outputs "<repo>" or "<repo>/<branch>" as initial title. The UserPromptSubmit
# hook (claude-session-title) overwrites this once the first user prompt arrives.

# Resolve repo name from git common dir (worktree-safe)
common_dir=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)
if [ -n "$common_dir" ]; then
  repo=$(basename "$(dirname "$common_dir")")
else
  repo=$(basename "$(pwd)")
fi

branch=$(git symbolic-ref --short HEAD 2>/dev/null)

if [ -n "$branch" ] && [ "$branch" != "main" ] && [ "$branch" != "master" ]; then
  title="$repo / $branch"
else
  title="$repo"
fi

jq -nc --arg t "$title" '{"hookSpecificOutput":{"hookEventName":"SessionStart","sessionTitle":$t}}'
