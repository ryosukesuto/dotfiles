#!/usr/bin/env bash
# PreToolUse(Write) hook: warn when creating a new Obsidian note without
# proper frontmatter (title / date / tags). Does not block — surfaces a
# suggestion so the agent can re-issue Write with the recommended frontmatter.
#
# Why: Obsidian convention in ~/gh/github.com/ryosukesuto/obsidian-notes/
# expects `---` frontmatter with `tags:` block so dataview queries
# (FROM #projects/aegis etc.) pick the note up. Without tags, notes get
# orphaned and lose discoverability.
#
# Detection scope:
#   - Tool: Write only (new file creation)
#   - Path: */obsidian-notes/*.md
#   - Skip: templates/ subdirectory
#
# Suggests tags based on filename heuristics:
#   - *Project-Aegis_* / *Aegis_*  → projects/aegis
#   - *_1on1_*                     → types/1on1
#   - *_MOC.md                     → types/moc
#   - *_daily.md                   → types/daily
#   - default                      → types/docs

set -euo pipefail

payload=$(cat)
tool_name=$(printf '%s' "$payload" | jq -r '.tool_name // ""')

# Write tool only (new file). Edit operations on existing files are out of scope.
[ "$tool_name" = "Write" ] || exit 0

file_path=$(printf '%s' "$payload" | jq -r '.tool_input.file_path // ""')
content=$(printf '%s' "$payload" | jq -r '.tool_input.content // ""')

# obsidian-notes/*.md のみ対象
case "$file_path" in
  */obsidian-notes/*.md) ;;
  *) exit 0 ;;
esac

# templates/ サブディレクトリは除外
case "$file_path" in
  */obsidian-notes/templates/*) exit 0 ;;
esac

filename=$(basename "$file_path")
first_line=$(printf '%s' "$content" | head -n 1)

# frontmatter あり (1 行目が ---) かつ tags 行ありなら OK
if [ "$first_line" = "---" ] && printf '%s' "$content" | head -n 20 | grep -qE '^tags:'; then
  exit 0
fi

# 警告メッセージ生成
{
  echo "[claude-guard-obsidian-frontmatter] WARNING:"
  if [ "$first_line" = "---" ]; then
    echo "  $file_path に frontmatter はあるが tags が見当たりません。"
  else
    echo "  $file_path に frontmatter がありません。"
  fi
  echo "  Obsidian dataview / 検索のため、以下の形で frontmatter を追加してください:"
  echo ""

  # ファイル名から推奨タグを組み立て
  echo "  ---"
  # title: 日付プレフィクスと拡張子を除去
  title=$(echo "$filename" | sed -E 's/^[0-9]{4}-[0-9]{2}-[0-9]{2}_//; s/\.md$//')
  echo "  title: \"$title\""
  echo "  date: $(date '+%Y-%m-%d')"
  echo "  tags:"

  case "$filename" in
    *Project-Aegis_*|*Aegis_*) echo "    - projects/aegis" ;;
  esac

  case "$filename" in
    *_1on1_*) echo "    - types/1on1" ;;
    *_MOC.md) echo "    - types/moc" ;;
    *_daily.md) echo "    - types/daily" ;;
    *) echo "    - types/docs" ;;
  esac

  echo "  ---"
  echo ""
} >&2

# 警告のみ。書き込みは許可する
exit 0
