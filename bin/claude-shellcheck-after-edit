#!/usr/bin/env bash
# PostToolUse(Edit|Write) hook: 編集対象が *.sh のとき shellcheck を実行し、
# warning / info / error を stderr に表示してユーザーへ即フィードバックする。
#
# Rule reference: ~/.claude/rules/shell-quality.md
#
# 設計方針:
# - shellcheck が未インストールの環境では silent skip (exit 0)
# - 編集対象が *.sh 以外なら silent skip (exit 0)
# - --severity=info で error / warning / info を stderr に表示。style は除外
# - error 重大度の指摘がある場合のみ exit 2 で Claude にフィードバック
#   (PostToolUse の exit 2 は stderr を Claude のコンテキストへ注入する)
# - warning / info のみなら exit 0。人間が transcript で確認するノイズ層

set -euo pipefail
export LC_ALL=C

payload=$(cat)
file=$(printf '%s' "$payload" | jq -r '.tool_response.filePath // .tool_input.file_path // empty')

case "$file" in
  *.sh) ;;
  *) exit 0 ;;
esac

command -v shellcheck >/dev/null 2>&1 || exit 0
[[ -f "$file" ]] || exit 0

# info 以上を表示。findings がある場合 shellcheck は非 0 を返すので || true で吸収
shellcheck --severity=info "$file" >&2 || true

# error 重大度のみで再走査。findings なし = exit 0、findings あり = 非 0
if shellcheck --severity=error "$file" >/dev/null 2>&1; then
  exit 0
fi

# error 重大度の findings 検出 → Claude に修正を促す
exit 2
